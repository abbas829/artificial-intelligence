{
  "experiment_name": "Image Classification v2",
  "model": {
    "architecture": "ResNet50",
    "pretrained": true,
    "dropout_rate": 0.3
  },
  "training": {
    "batch_size": 32,
    "learning_rate": 0.001,
    "epochs": 150,
    "optimizer": "Adam",
    "scheduler": {
      "type": "ReduceLROnPlateau",
      "patience": 5
    }
  },
  "data": {
    "train_split": 0.8,
    "augmentation": [
      "flip",
      "rotate",
      "zoom"
    ],
    "normalize": true
  },
  "logging": {
    "log_dir": "./logs",
    "checkpoint_freq": 10
  }
}